# -----------------------------------------------------------------------------
# Documentation portals (human-facing; not HTTP API hosts)
# Use these pages to create or rotate API keys.
# -----------------------------------------------------------------------------
OPEN_FDA_SITE=https://open.fda.gov/apis/authentication/
NCBI_SITE=https://account.ncbi.nlm.nih.gov/settings/

# -----------------------------------------------------------------------------
# OpenFDA API (JSON). Keys are optional but raise rate limits when set.
# https://open.fda.gov/apis/
# -----------------------------------------------------------------------------
OPENFDA_API_BASE=https://api.fda.gov
# Optional; leave empty for anonymous quota
OPENFDA_API_KEY=

# Legacy alias supported by sim.settings: OPEN_FDA_API_KEY

# -----------------------------------------------------------------------------
# NCBI E-utilities (Entrez). API key optional; increases rate limit when set.
# https://www.ncbi.nlm.nih.gov/books/NBK25497/
# -----------------------------------------------------------------------------
NCBI_EUTILS_BASE=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
NCBI_API_KEY=

# -----------------------------------------------------------------------------
# Optional: LLM routing (later phases; not used by sim.settings yet)
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
DATA_DIR=data
LOG_LEVEL=INFO

# Optional tuning for later ingestion scripts (requests/sec cap hint)
HTTP_MAX_RETRIES=5
HTTP_BACKOFF_BASE_SECONDS=0.5
# Outbound HTTP timeouts (seconds); increase on slow or flaky networks / WSL
HTTP_CONNECT_TIMEOUT=90
HTTP_READ_TIMEOUT=120
# Set to 1 on WSL if IPv6 is unrouted (curl shows "Network is unreachable" for IPv6)
HTTP_FORCE_IPV4=1
